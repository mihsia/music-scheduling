// Firestore 安全規則 — 登入 + Google 帳號白名單
// 貼到 Firebase Console → Firestore Database → 規則(Rules) → 發布。
//
// 規則會讀取 meta/settings 文件的 allowedEmails 陣列：
//   - 沒有 settings 文件,或 allowedEmails 為空 → 任何登入者皆可讀寫(方便初次建置)。
//   - allowedEmails 有值 → 僅清單內的 Email 可讀寫。
// 這份清單可直接在系統的「系統設定」頁編輯,會即時生效。
//
// ⚠️ 設定白名單時務必包含自己的 Email,否則會把自己鎖在外面
//    (若不慎鎖住,可在 Console → Firestore → meta/settings 手動清空 allowedEmails)。
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function settingsData() {
      return exists(/databases/$(database)/documents/meta/settings)
        ? get(/databases/$(database)/documents/meta/settings).data
        : null;
    }
    function allowList() {
      let s = settingsData();
      return (s == null || !('allowedEmails' in s)) ? [] : s.allowedEmails;
    }
    function isAllowed() {
      return request.auth != null
        && (allowList().size() == 0 || request.auth.token.email in allowList());
    }

    match /{document=**} {
      allow read, write: if isAllowed();
    }
  }
}
